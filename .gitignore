# Local, per-user Claude Code settings (personal permission grants, etc.)
.claude/settings.local.json

# Per-user config written by /configure-collab (personal deny/ask/allow rules and
# preferred models; ask.sh/panel-models auto-prefer these). Never commit personal
# prefs. The committed collab.conf.example is the template.
collab/models.policy.local
collab/collab.conf.local

# Secrets / local env — never commit these
.env
*.env
!*.env.example

# macOS
.DS_Store

# Node (opencode/claude are installed globally; this is just in case deps land here)
node_modules/

# opencode project-local install cruft (created when opencode resolves an agent
# def in .opencode/); we commit .opencode/agent/*.md, not the package manifests.
.opencode/package.json
.opencode/package-lock.json
.opencode/bun.lock

# Probe sentinels the verify scripts create (and normally clean up); ignore any that
# linger if a run is interrupted mid-probe.
.collab-*-probe.*

# The evidence layer (collab/log.sh): raw model calls, prompts and responses from
# every /consult, /panel, /delegate … Local audit data for the watcher — it holds
# whatever repo context was pasted into a prompt, so it is never committed.
collab/logs/

# Logs / temp
*.log
