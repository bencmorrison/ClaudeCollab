# Local, per-user Claude Code settings (personal permission grants, etc.)
.claude/settings.local.json

# Per-user config written by /guild:configure (personal deny/ask/allow rules and
# preferred models; the guild MCP tools read these). Never commit personal
# prefs. The committed modelguild.conf.example is the template.
modelguild/models.policy.local
modelguild/modelguild.conf.local

# This repo registers the modelguild MCP server per-user (see README "Register the
# server"), so our own .mcp.json is a private local registration with a machine-specific
# launch path — never commit it. NOTE: this is a THIS-REPO choice, not the installer's:
# `init` does NOT gitignore .mcp.json in projects it installs into, because a project-scoped
# .mcp.json (`claude mcp add -s project` / `--write-mcp`) is designed to be committed for
# team sharing. Commit it there for a shared team registration; gitignore it for a personal one.
.mcp.json

# Secrets / local env — never commit these
.env
*.env
!*.env.example

# macOS
.DS_Store

# Node (opencode/claude are installed globally; this is just in case deps land here)
node_modules/

# TS/MCP rewrite build output (tsconfig outDir); tests run via tsx, not a build.
dist/

# opencode project-local install cruft (created when opencode resolves an agent
# def in .opencode/); we commit .opencode/agent/*.md, not the package manifests.
.opencode/package.json
.opencode/package-lock.json
.opencode/bun.lock

# Probe sentinels the verify scripts create (and normally clean up); ignore any that
# linger if a run is interrupted mid-probe.
.guild-*-probe.*

# The evidence layer (src/log.ts): raw model calls, prompts and responses from
# every /guild:consult, /guild:panel, /guild:delegate, etc. Local receipts — they hold
# whatever repo context was pasted into a prompt, so they are never committed.
modelguild/logs/

# Host-side staging for selected devcontainer Claude config. Recreated before the
# container starts; never commit personal config copied here.
.devcontainer/.host-config/

# Logs / temp
*.log
