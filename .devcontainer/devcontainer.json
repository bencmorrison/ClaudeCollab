{
  // ClaudeCollab dev container — Claude Code + opencode both run in here.
  // Host LLM subscription credentials are bind-mounted read-only (see below).
  //
  // The initializeCommand below creates empty placeholder credential files on the
  // host if they don't exist yet, so the container always starts. To actually reach
  // the models, authenticate on the HOST, then rebuild/restart the container:
  //   opencode auth login          # writes real creds to ~/.local/share/opencode/auth.json
  //   claude                       # ~/.claude/.credentials.json (already present once logged in)
  "name": "ClaudeCollab",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "node",

  // Runs on the HOST before the container is created. Guarantees the bind-mount
  // sources exist (Docker errors if a mount source file is missing). Never
  // overwrites real credentials — only creates an empty {} placeholder if absent.
  "initializeCommand": [
    "bash", "-c",
    "mkdir -p \"$HOME/.local/share/opencode\" \"$HOME/.claude\" \"$HOME/.config/opencode\"; [ -s \"$HOME/.local/share/opencode/auth.json\" ] || echo '{}' > \"$HOME/.local/share/opencode/auth.json\"; [ -s \"$HOME/.claude/.credentials.json\" ] || echo '{}' > \"$HOME/.claude/.credentials.json\""
  ],

  "mounts": [
    // opencode subscription auth (OpenAI / Copilot / Gemini). Must exist on host first.
    "source=${localEnv:HOME}/.local/share/opencode/auth.json,target=/home/node/.local/share/opencode/auth.json,type=bind,readonly",
    // opencode config (models, defaults).
    "source=${localEnv:HOME}/.config/opencode,target=/home/node/.config/opencode,type=bind,readonly",
    // Claude Code subscription auth.
    // NOTE: readonly means the container cannot refresh an expired OAuth token.
    // If in-container auth lapses, either run `claude` on the host to refresh, or
    // drop `,readonly` from the two lines above/below so the container can refresh.
    "source=${localEnv:HOME}/.claude/.credentials.json,target=/home/node/.claude/.credentials.json,type=bind,readonly"
  ],

  "containerEnv": {
    // Default model for /consult (optional). Forwarded from host if set.
    "COLLAB_MODEL": "${localEnv:COLLAB_MODEL}"
    // If your host Claude relies on a custom endpoint, add:
    // "ANTHROPIC_BASE_URL": "${localEnv:ANTHROPIC_BASE_URL}"
  },

  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  },

  "postCreateCommand": "bash .devcontainer/postCreate.sh"
}
