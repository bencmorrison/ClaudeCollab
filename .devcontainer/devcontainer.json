{
  // ClaudeCollab dev container — Claude Code + opencode both run in here.
  //
  // Auth model: you log in ONCE inside the container. Login state is kept in the
  // named volumes below, so it survives rebuilds and the agents can refresh their
  // own OAuth tokens (no host credential mounts — those don't work for a non-root
  // container user on macOS, where secrets are mode 600 / root-owned via the mount).
  //
  //   claude                 -> then /login  (device-code OAuth in your browser)
  //   opencode auth login    -> pick OpenAI / Copilot / Gemini
  "name": "ClaudeCollab",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "node",

  "features": {
    // GitHub CLI (gh) for repo / PR / Actions work. Installed as a Feature so it
    // persists across rebuilds; its auth lives in the claudecollab-gh volume below.
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "mounts": [
    // Persistent login/state volumes. Seeded node-owned from the image dirs on
    // first use (see the mkdir+chown in the Dockerfile), so the node user can write.
    "source=claudecollab-claude,target=/home/node/.claude,type=volume",
    "source=claudecollab-opencode,target=/home/node/.local/share/opencode,type=volume",
    // gh CLI auth (device-code login persists here across rebuilds).
    "source=claudecollab-gh,target=/home/node/.config/gh,type=volume",

    // Your host user-level Claude config, mounted read-only at a staging path so
    // host edits show through. postCreate links the safe pieces (CLAUDE.md,
    // commands, agents) into the active ~/.claude; settings.json is left staged
    // for review (host hooks/statusLine/paths may not work in-container). Reads
    // only world-readable config — never host credentials (600/root-owned on
    // macOS). Whole-dir mount avoids per-file rebuild failures on missing paths.
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude-host,type=bind,readonly",
    // Many setups (incl. this one) symlink ~/.claude/* into a dotfiles repo, so
    // mount ~/.dotfiles too — otherwise those symlinks dangle in the container.
    "source=${localEnv:HOME}/.dotfiles,target=/home/node/.dotfiles,type=bind,readonly"
  ],

  "containerEnv": {
    // Default model for /consult (optional). Forwarded from host if set.
    "COLLAB_MODEL": "${localEnv:COLLAB_MODEL}"
    // If your host Claude relies on a custom endpoint, add:
    // "ANTHROPIC_BASE_URL": "${localEnv:ANTHROPIC_BASE_URL}"
  },

  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  },

  "postCreateCommand": "bash .devcontainer/postCreate.sh"
}
