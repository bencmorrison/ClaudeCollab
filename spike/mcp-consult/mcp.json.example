{
  "mcpServers": {
    "mcp-consult-spike": {
      "command": "npx",
      "args": ["tsx", "spike/mcp-consult/src/server.ts"],
      "env": {
        "COLLAB_SPIKE_REAL": "1",
        "COLLAB_PROJECT_DIR": "/absolute/path/to/your/project",
        "COLLAB_SPIKE_MODEL": "opencode/deepseek-v4-flash-free",
        "COLLAB_SPIKE_LOG": "/absolute/path/to/spike-log.jsonl"
      }
    }
  }
}
