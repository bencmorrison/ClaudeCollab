{
  "name": "claudecollab",
  "version": "0.5.0",
  "type": "module",
  "description": "An MCP server fronting `opencode serve`, letting Claude Code collaborate with other LLMs (consult, panel, research, review, delegate). Ships slash commands + hardened opencode agents; `npx claudecollab init` wires it into a project. The bash layer in collab/ was retired at 0.5.0 (PLAN.md M12); this is the sole path now.",
  "license": "MIT",
  "author": "Benjamin Beno Morrison <ai@bcm.co>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bencmorrison/ClaudeCollab.git"
  },
  "homepage": "https://github.com/bencmorrison/ClaudeCollab#readme",
  "bugs": {
    "url": "https://github.com/bencmorrison/ClaudeCollab/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "opencode",
    "llm",
    "multi-model",
    "code-review",
    "anthropic"
  ],
  "bin": {
    "claudecollab": "dist/cli.js"
  },
  "files": [
    "dist/",
    ".claude/commands/collab/consult.md",
    ".claude/commands/collab/panel.md",
    ".claude/commands/collab/research.md",
    ".claude/commands/collab/review.md",
    ".claude/commands/collab/delegate.md",
    ".claude/commands/collab/workshop.md",
    ".claude/commands/collab/collaborate.md",
    ".claude/commands/collab/configure.md",
    ".opencode/agent/collab-read.md",
    ".opencode/agent/collab-build.md",
    ".opencode/agent/collab-research.md",
    "collab/models.policy",
    "collab/collab.conf.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/server.ts",
    "test": "tsx test/run.ts",
    "test:live": "tsx test/client.live.ts && tsx test/consult.live.ts && tsx test/panel.live.ts && tsx test/research.live.ts && tsx test/delegate.live.ts && tsx test/session.live.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.18.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
